# ============================================================
# Environment Variables Example
# Copy this file to .env.local for development
# Copy this file to .env.production for production
# ============================================================

# Database
# Development: Use local SQLite database
# Production: Use your production database URL
DATABASE_URL="file:../db/hamsou.db?connection_limit=1"

# JWT Secret (Required - Change this to a secure random string)
# Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-key-change-in-production"

# App Environment
# development | production | test
NODE_ENV="development"

# AI Provider (Optional - defaults to z-ai)
# Options: z-ai | openai | anthropic
AI_PROVIDER="z-ai"

# OpenAI API Key (Only if AI_PROVIDER=openai)
# OPENAI_API_KEY="sk-..."

# Anthropic API Key (Only if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY="sk-ant-..."
