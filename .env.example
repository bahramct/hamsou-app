# ============================================================
# Environment Variables Example
# Copy this file to .env.local for development
# Copy this file to .env.production for production
# ============================================================

# Database
# Development: Use local SQLite database (db/hamsou-dev.db)
# Production: Use production database (db/hamsou-prod.db)
DATABASE_URL="file:db/hamsou-dev.db?connection_limit=1"

# JWT Secret (Required - Change this to a secure random string)
# Development: Use a simple secret (only for development!)
# Production: Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-key-change-in-production"

# App Environment
# development | production | test
NODE_ENV="development"

# AI Provider (Optional - defaults to z-ai)
# Options: z-ai | openai | anthropic
AI_PROVIDER="z-ai"

# Disable Development Tools (Production only)
# Set to "true" in production to disable all dev endpoints
DISABLE_DEV_TOOLS="true"
