generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../db/hamsou.db"
}

// کاربران
model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  bio       String?
  profileImage String?

  // تنظیمات حریم خصوصی (JSON)
  privacySettings String? @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // تنظیمات نوتیفیکیشن
  notificationTime    String  @default("09:00") // HH:mm format
  notificationEnabled Boolean @default(true)

  // اشتراک
  subscriptionPlan  String   @default("free") // free, plus, pro
  subscriptionStart DateTime @default(now())
  subscriptionEnd   DateTime?

  // روابط
  commitments    Commitment[]
  weeklyReports  WeeklyReport[]
  plans          Plan[]
  settings       UserSettings?
  notifications  Notification[]
  sharedReports  SharedReport[]
  sharedAchievements SharedAchievement[]

  // روابط اجتماعی
  posts Post[]
  likes Like[]
  comments Comment[]
  following Follow[] @relation("FollowingUser")
  followers Follow[] @relation("FollowerUser")
  challengesChallenge Challenge[] @relation("ChallengeCreator")
  challengesParticipated ChallengeParticipant[]

  @@map("users")
}

// تنظیمات کاربر
model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme    String @default("light") // light, dark, system
  language String @default("fa")
  timeZone String @default("Asia/Tehran")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

// تعهدات روزانه
model Commitment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  text String
  date DateTime @default(now()) // روز ثبت تعهد

  planId      String?
  plan        Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)

  reflection Reflection?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@map("commitments")
}

// بازتاب‌ها
model Reflection {
  id           String     @id @default(cuid())
  commitmentId String     @unique
  commitment   Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)

  completed Boolean // آیا تعهد انجام شد؟
  reason    String? // دلیل عدم انجام (اگر completed = false)

  reflectedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("reflections")
}

// گزارش‌های هفتگی AI
model WeeklyReport {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekStart DateTime // شروع هفته
  weekEnd   DateTime // پایان هفته

  // داده‌های گزارش
  consistencyScore     Float?  // نمره一致性 (0-1)
  completionPattern    String? // JSON string
  behavioralFriction   String? // JSON string
  emotionalTone        String? // JSON string
  weeklySummary        String? // خلاصه هفتگی
  behavioralInsight    String? // Insight رفتاری
  suggestedDirection   String? // جهت پیشنهادی آگاهی

  // محتوای کامل گزارش
  reportContent String // JSON

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, weekStart])
  @@map("weekly_reports")
}

// برنامه‌ریزی‌ها و اهداف
model Plan {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String   // عنوان برنامه
  description String?  // توضیحات

  // نوع برنامه
  type        String   @default("daily") // daily, weekly, monthly, custom
  category    String   @default("personal") // personal, work, health, learning, etc.

  // بازه زمانی
  startDate   DateTime // تاریخ شروع
  endDate     DateTime? // تاریخ پایان (برای برنامه‌های محدود)

  // اهداف و متریک‌ها
  targetDays  Int?     // تعداد روز هدف (مثلاً 30 روز متوالی)
  currentDays Int      @default(0) // تعداد روزهای انجام شده

  // وضعیت
  status      String   @default("active") // active, paused, completed, archived

  // اولویت
  priority    String   @default("medium") // low, medium, high

  commitments Commitment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("plans")
}

// نوتیفیکیشن‌ها
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // نوع نوتیفیکیشن
  type      String // commitment_reminder, plan_completed, reflection_reminder, weekly_report, achievement, etc.

  // محتوا
  title     String
  message   String

  // وضعیت
  read      Boolean  @default(false)
  readAt    DateTime?

  // اقدام (اختیاری)
  actionUrl String?  // URL برای وقتی روی نوتیفیکیشن کلیک می‌شود
  actionLabel String? // متن دکمه اقدام

  // داده‌های اضافی (JSON)
  metadata   String? // برای ذخیره داده‌های اضافی مثل planId, commitmentId, etc.

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

// گزارش‌های اشتراک‌گذاری شده
model SharedReport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // اطلاعات گزارش
  shareToken  String   @unique // توکن یکتا برای اشتراک‌گذاری
  title       String?  // عنوان گزارش
  description String?  // توضیحات
  reportType  String   @default("analytics") // analytics, weekly, monthly

  // محتوای گزارش (JSON)
  data        String   // داده‌های گزارش به صورت JSON

  // تنظیمات اشتراک
  expiresAt   DateTime? // زمان انقضا
  password    String?   // رمز عبور (اختیاری)
  views       Int      @default(0) // تعداد بازدیدها
  maxViews    Int?     // حداکثر تعداد بازدید

  // وضعیت
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, isActive])
  @@index([shareToken])
  @@map("shared_reports")
}

// دستاوردهای اشتراک‌گذاری شده
model SharedAchievement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // اطلاعات اشتراک
  shareToken  String   @unique // توکن یکتا برای اشتراک‌گذاری
  achievementType String // commitment, streak, plan_completed

  // داده‌های دستاورد (JSON)
  data        String   // داده‌های دستاورد به صورت JSON

  // متادیتای نمایشی
  title       String?  // عنوان نمایشی
  description String?  // توضیحات

  // تنظیمات اشتراک
  expiresAt   DateTime? // زمان انقضا
  views       Int      @default(0) // تعداد بازدیدها
  maxViews    Int?     // حداکثر تعداد بازدید

  // وضعیت
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, isActive])
  @@index([shareToken])
  @@map("shared_achievements")
}

// ============= مدل‌های جامعه (Community) =============

// پست‌های جامعه
model Post {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // محتوای پست
  content     String   // متن پست
  postType    String   @default("achievement") // achievement, reflection, update, challenge

  // داده‌های اضافی (JSON)
  metadata    String?  // برای ذخیره داده‌های اضافی مثل achievementData, stats, etc.

  // تنظیمات نمایش
  visibility  String   @default("public") // public, followers, private
  isPinned    Boolean  @default(false)

  // آمار
  likesCount  Int      @default(0)
  commentsCount Int    @default(0)
  viewsCount  Int      @default(0)

  // روابط
  likes       Like[]
  comments    Comment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("posts")
}

// لایک‌ها
model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
  @@map("likes")
}

// کامنت‌ها
model Comment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  // محتوا
  content   String

  // پاسخ به کامنت دیگر
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([parentId])
  @@map("comments")
}

// دنبال کردن کاربران
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("FollowerUser", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("FollowingUser", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// چالش‌های گروهی
model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String?
  creatorId   String
  creator     User     @relation("ChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  // نوع و دسته‌بندی
  type        String   // daily_commitment, weekly_streak, monthly_goal
  category    String   @default("general") // fitness, learning, productivity, etc.

  // تنظیمات چالش
  startDate   DateTime
  endDate     DateTime
  targetValue Int?     // مقدار هدف (مثلاً 30 روز متوالی)
  participantLimit Int? // محدودیت تعداد شرکت‌کنندگان

  // وضعیت
  status      String   @default("active") // active, completed, cancelled

  // آمار
  participantCount Int @default(0)

  // روابط
  participants ChallengeParticipant[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, startDate])
  @@index([category])
  @@map("challenges")
}

// شرکت‌کنندگان چالش
model ChallengeParticipant {
  id          String   @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // پیشرفت کاربر در چالش
  currentValue Int   @default(0) // مقدار فعلی
  isCompleted   Boolean @default(false)
  completedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([challengeId, userId])
  @@index([challengeId])
  @@index([userId])
  @@map("challenge_participants")
}
